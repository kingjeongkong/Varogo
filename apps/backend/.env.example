# App
PORT=3000
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3001
# Set in production to share cookies between frontend and api subdomains (e.g. .varo-go.com)
COOKIE_DOMAIN=

# Database
DATABASE_URL="postgresql://varogo:varogo_password@localhost:5432/varogo_db"

# JWT
JWT_SECRET=
JWT_EXPIRES_MINUTES=15
REFRESH_TOKEN_EXPIRES_IN=7

# Gemini
GEMINI_API_KEY=

# OpenAI — option generation (post-draft)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# LangSmith — tracing and evaluation (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://aws.api.smith.langchain.com
LANGSMITH_PROJECT=Varogo

# Threads
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_REDIRECT_URI=
# 64-character hex string — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
THREADS_TOKEN_ENCRYPTION_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry (optional)
SENTRY_DSN=

# Discord notifications (optional)
DISCORD_WEBHOOK_SIGNUPS=
DISCORD_WEBHOOK_PUBLISHED=
DISCORD_WEBHOOK_ERRORS=

# AWS SES (email — for password reset)
# EC2 IAM role이 있으면 ACCESS_KEY 불필요, REGION과 FROM_EMAIL만 설정
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=noreply@varo-go.com

# Stripe (v0.9)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
