generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  name              String?
  passwordHash      String?            @map("password_hash")
  avatarUrl         String?            @map("avatar_url")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  accounts          Account[]
  refreshTokens     RefreshToken[]
  products          Product[]
  voiceProfile      VoiceProfile?
  threadsConnection ThreadsConnection?

  @@map("users")
}

model Account {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  provider   String
  providerId String   @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  url             String
  oneLiner        String   @map("one_liner")
  stage           String
  currentTraction Json     @map("current_traction")
  additionalInfo  String?  @map("additional_info")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis ProductAnalysis?
  posts    PostDraft[]

  @@index([userId])
  @@map("products")
}

model ProductAnalysis {
  id                   String   @id @default(uuid())
  productId            String   @unique @map("product_id")
  category             String
  jobToBeDone          String   @map("job_to_be_done")
  whyNow               String   @map("why_now")
  targetAudience       Json     @map("target_audience")
  valueProposition     String   @map("value_proposition")
  alternatives         Json
  differentiators      String[]
  positioningStatement String   @map("positioning_statement")
  keywords             Json
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_analyses")
}

model VoiceProfile {
  id               String   @id @default(uuid())
  userId           String   @unique @map("user_id")
  source           String
  sampleCount      Int      @map("sample_count")
  styleFingerprint Json     @map("style_fingerprint")
  referenceSamples Json     @map("reference_samples")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_profiles")
}

model PostDraft {
  id             String    @id @default(uuid())
  productId      String    @map("product_id")
  todayInput     String?   @map("today_input")
  selectedHookId String?   @map("selected_hook_id")
  body           String
  status         String
  publishedAt    DateTime? @map("published_at")
  threadsMediaId String?   @map("threads_media_id")
  permalink      String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  hookOptions  HookOption[] @relation("DraftHooks")
  selectedHook HookOption?  @relation("SelectedHook", fields: [selectedHookId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([status])
  @@map("post_drafts")
}

model HookOption {
  id          String   @id @default(uuid())
  postDraftId String   @map("post_draft_id")
  text        String
  angleLabel  String   @map("angle_label")
  createdAt   DateTime @default(now()) @map("created_at")

  postDraft  PostDraft   @relation("DraftHooks", fields: [postDraftId], references: [id], onDelete: Cascade)
  selectedBy PostDraft[] @relation("SelectedHook")

  @@index([postDraftId])
  @@map("hook_options")
}

model ThreadsConnection {
  id                   String   @id @default(uuid())
  userId               String   @unique @map("user_id")
  threadsUserId        String   @map("threads_user_id")
  username             String?
  accessTokenEncrypted String   @map("access_token_encrypted")
  tokenExpiresAt       DateTime @map("token_expires_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("threads_connections")
}
