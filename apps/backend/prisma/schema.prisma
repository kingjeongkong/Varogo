generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  name         String?
  passwordHash String?        @map("password_hash")
  avatarUrl    String?        @map("avatar_url")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  accounts      Account[]
  refreshTokens RefreshToken[]
  products      Product[]

  @@map("users")
}

model Account {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  provider   String
  providerId String   @map("provider_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Product {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  url             String
  oneLiner        String   @map("one_liner")
  stage           String
  currentTraction Json     @map("current_traction")
  additionalInfo  String?  @map("additional_info")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  analyses ProductAnalysis[]

  @@index([userId])
  @@map("products")
}

model ProductAnalysis {
  id                   String   @id @default(uuid())
  productId            String   @map("product_id")
  targetAudience       Json     @map("target_audience")
  problem              String
  valueProposition     String   @map("value_proposition")
  alternatives         Json
  differentiators      String[]
  positioningStatement String   @map("positioning_statement")
  keywords             Json
  createdAt            DateTime @default(now()) @map("created_at")

  product                Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  channelRecommendations ChannelRecommendation[]

  @@index([productId])
  @@map("product_analyses")
}

model ChannelRecommendation {
  id                 String   @id @default(uuid())
  productAnalysisId  String   @map("product_analysis_id")
  channelName        String   @map("channel_name")
  tier               String
  scoreBreakdown     Json     @map("score_breakdown")
  whyThisChannel     String   @map("why_this_channel")
  distributionMethod String   @map("distribution_method")
  contentAngle       String   @map("content_angle")
  risk               String
  effortLevel        String   @map("effort_level")
  effortDetail       String   @map("effort_detail")
  expectedTimeline   String   @map("expected_timeline")
  successMetric      String   @map("success_metric")
  createdAt          DateTime @default(now()) @map("created_at")

  productAnalysis ProductAnalysis @relation(fields: [productAnalysisId], references: [id], onDelete: Cascade)
  strategies      Strategy[]

  @@index([productAnalysisId])
  @@map("channel_recommendations")
}

model Strategy {
  id                      String   @id @default(uuid())
  channelRecommendationId String   @map("channel_recommendation_id")

  // 전략 방향
  title       String
  description String
  coreMessage String @map("core_message")
  approach    String
  whyItFits   String @map("why_it_fits")

  // 콘텐츠 타입 (Phase 1: Strategy와 1:1 매칭)
  contentTypeTitle       String @map("content_type_title")
  contentTypeDescription String @map("content_type_description")

  createdAt DateTime @default(now()) @map("created_at")

  channelRecommendation ChannelRecommendation    @relation(fields: [channelRecommendationId], references: [id], onDelete: Cascade)
  contentTemplate       StrategyContentTemplate?
  content               Content?

  @@index([channelRecommendationId])
  @@map("strategies")
}

model StrategyContentTemplate {
  id          String   @id @default(uuid())
  strategyId  String   @unique @map("strategy_id")
  sections    Json
  overallTone String   @map("overall_tone")
  lengthGuide String   @map("length_guide")
  createdAt   DateTime @default(now()) @map("created_at")

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("strategy_content_templates")
}

model Content {
  id         String   @id @default(uuid())
  strategyId String   @unique @map("strategy_id")
  body       String
  createdAt  DateTime @default(now()) @map("created_at")

  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@map("contents")
}

